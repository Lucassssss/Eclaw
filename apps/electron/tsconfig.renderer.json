{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/renderer",
    "rootDir": "src/renderer",
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": ["src/renderer/**/*"],
  "exclude": ["node_modules"]
}
