{
  "name": "eclaw",
  "version": "1.0.0",
  "private": true,
  "description": "Eclaw Desktop Application",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && electron .",
    "dev:renderer": "echo 'Use http://localhost:3000'",
    "build": "npm run build:web && npm run build:api && npm run build:main && npm run build:preload",
    "build:web": "cd ../web && NEXT_PUBLIC_API_URL=http://localhost:26318 bun run build",
    "build:api": "cd ../api && bun run build:bin",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-log": "^5.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.eclaw.desktop",
    "productName": "Eclaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "web",
        "filter": ["**/*"]
      },
      {
        "from": "../api/.bin/server",
        "to": "api/server",
        "filter": ["**/*"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Lucassssss",
      "repo": "Eclaw"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  }
}
